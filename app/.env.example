# Akoúō App Local Environment
VITE_AKOUO_BENCHMARK_API=http://localhost:8787

# Optional: only set this if BENCH_API_KEY is enabled on the benchmark server.
# Browser env values are visible to local app users, so use a local-only key
# and list the exact benchmark origin that may receive it.
VITE_AKOUO_BENCHMARK_API_KEY=replace-with-local-bench-key
VITE_AKOUO_BENCHMARK_TRUSTED_ORIGINS=http://localhost:8787

# Optional: expose the Vite dev server beyond localhost.
# If enabled, set explicit hosts instead of using Vite's unsafe allow-all mode.
AKOUO_EXPOSE_DEV_SERVER=false
AKOUO_ALLOWED_HOSTS=
