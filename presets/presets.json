        { "mode": "acoulogical-object-listening", "role": "secondary" },
        { "mode": "signal-inspection-listening", "role": "corrective" }
      ],
      "cost_tier": "standard",
      "memory_policy": "read_write",
      "perception_passes": ["caption", "dsp"],
      "enabled_by_default": true
    },
    {
      "id": "deep",
      "name": "Deep",
      "description": "Full survey: every relevant perception pass and a broad mode chain, with memory comparison available.",
      "command": "/full-ear",
      "mode_chain": [
        { "mode": "signal-inspection-listening", "role": "primary" },
        { "mode": "acoulogical-object-listening", "role": "secondary" },
        { "mode": "musical-aesthetic-listening", "role": "optional" },
