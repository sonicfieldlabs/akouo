{
  "akouo_version": "0.8",
  "description": "Portable listening presets: named configurations for recurring use-cases. Each preset validates against schemas/preset.schema.json. Hosts map perception_passes to their own backends; 'dsp' means deterministic signal measurement, the others are model perception passes. The router may still add or strengthen a corrective mode when the object's risk demands it — presets configure listening, they never waive guardrails.",
  "presets": [
    {
      "id": "basic",
      "name": "Basic",
      "description": "Fast first pass: one perceptual description plus measured signal facts under full claim discipline.",
      "command": "/listen",
      "mode_chain": [
        { "mode": "acoulogical-object-listening", "role": "primary" },
        { "mode": "signal-inspection-listening", "role": "secondary" },
        { "mode": "transductive-media-listening", "role": "corrective" }
      ],
      "cost_tier": "light",
      "memory_policy": "none",
      "perception_passes": ["caption", "dsp"],
      "enabled_by_default": true
    },
    {
      "id": "signal",
      "name": "Signal",
      "description": "Technical diagnostics with measured facts only; no model perception passes.",
      "command": "/tech",
      "mode_chain": [
        { "mode": "signal-inspection-listening", "role": "primary" },
        { "mode": "transductive-media-listening", "role": "secondary" }
      ],
      "cost_tier": "light",
      "memory_policy": "none",
      "perception_passes": ["dsp"],
      "enabled_by_default": true
    },
    {
      "id": "field",
      "name": "Field",
      "description": "Soundscape and ecology listening for field recordings, rooms, infrastructure, and ambience.",
      "command": "/field",
      "mode_chain": [
        { "mode": "ecological-posthuman-listening", "role": "primary" },
        { "mode": "transductive-media-listening", "role": "secondary" },
        { "mode": "critical-political-listening", "role": "corrective" },
        { "mode": "material-event-listening", "role": "optional" }
      ],
      "cost_tier": "standard",
      "memory_policy": "none",
      "perception_passes": ["caption", "events", "dsp"],
      "enabled_by_default": true
    },
    {
      "id": "music",
      "name": "Music",
      "description": "Musical and production-oriented listening with genre and cultural caution.",
      "command": "/listen",
      "mode_chain": [
        { "mode": "musical-aesthetic-listening", "role": "primary" },
        { "mode": "signal-inspection-listening", "role": "secondary" },
        { "mode": "critical-political-listening", "role": "corrective" }
      ],
      "cost_tier": "standard",
      "memory_policy": "none",
      "perception_passes": ["music", "caption", "dsp"],
      "enabled_by_default": true
    },
    {
      "id": "voice",
      "name": "Voice",
      "description": "Speech and transcript route with identity, consent, and access caution.",
      "command": "/voice",
      "mode_chain": [
