      "cost_tier": "standard",
      "memory_policy": "none",
      "perception_passes": ["transcribe", "speech", "dsp"],
      "enabled_by_default": true
    },
    {
      "id": "recall",
      "name": "Recall",
      "description": "Listening with memory: compares the current sound against stored sound-memory records without writing anything.",
      "command": "/listen",
      "mode_chain": [
        { "mode": "memory-lineage-listening", "role": "primary" },
        { "mode": "acoulogical-object-listening", "role": "secondary" },
        { "mode": "transductive-media-listening", "role": "corrective" }
      ],
      "cost_tier": "standard",
      "memory_policy": "read",
      "perception_passes": ["caption", "dsp"],
      "enabled_by_default": true
    },
    {
      "id": "remember",
      "name": "Remember",
