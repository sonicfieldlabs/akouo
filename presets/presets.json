    {
      "id": "extended-spectrum",
      "name": "Extended Spectrum",
      "description": "Measurement-first route that states sample-rate and capture-chain limits before any ultrasonic or infrasonic interpretation.",
      "command": "/tech",
      "mode_chain": [
        { "mode": "signal-inspection-listening", "role": "primary" },
        { "mode": "material-event-listening", "role": "secondary" },
        { "mode": "transductive-media-listening", "role": "corrective" }
